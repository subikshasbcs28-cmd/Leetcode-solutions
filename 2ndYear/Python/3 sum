class Solution:
    def threeSum(self, nums: list[int]) -> list[list[int]]:
        res = []
        nums.sort()  # Sorting handles duplicates and enables two pointers
        
        for i, a in enumerate(nums):
            # If the fixed element is > 0, no triplet can sum to 0 anymore
            if a > 0:
                break
            
            # Skip the same value as the previous iteration to avoid duplicate triplets
            if i > 0 and a == nums[i - 1]:
                continue
                
            l, r = i + 1, len(nums) - 1
            while l < r:
                three_sum = a + nums[l] + nums[r]
                if three_sum > 0:
                    r -= 1
                elif three_sum < 0:
                    l += 1
                else:
                    res.append([a, nums[l], nums[r]])
                    l += 1
                    r -= 1
                    # Skip duplicate values for the left pointer
                    while nums[l] == nums[l - 1] and l < r:
                        l += 1
                        
        return res
