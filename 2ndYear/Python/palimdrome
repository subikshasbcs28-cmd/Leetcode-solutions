class Solution:
    def isPalindrome(self, x: int) -> bool:
        # Step 1: Handle edge cases
        # Negative numbers are not palindromes (e.g., -121 != 121-)
        # Numbers ending in 0 are not palindromes (except 0 itself)
        if x < 0 or (x % 10 == 0 and x != 0):
            return False
            
        reversed_half = 0
        # Step 2: Reverse only the second half of the number
        # We know we've reached the middle when x <= reversed_half
        while x > reversed_half:
            reversed_half = (reversed_half * 10) + (x % 10)
            x //= 10
            
        # Step 3: Compare both halves
        # For even number of digits (e.g., 1221), x will be 12 and reversed_half will be 12
        # For odd number of digits (e.g., 121), x will be 1 and reversed_half will be 12
        # So we use reversed_half // 10 to ignore the middle digit
        return x == reversed_half or x == reversed_half // 10
        
