# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next

class Solution:
    def addTwoNumbers(self, l1: Optional[ListNode], l2: Optional[ListNode]) -> Optional[ListNode]:
        # Dummy node to act as the starting point of the result list
        dummy = ListNode(0)
        curr = dummy
        carry = 0
        
        # Continue as long as there are nodes to process or a carry exists
        while l1 or l2 or carry:
            # Get values from nodes, or 0 if the list has ended
            val1 = l1.val if l1 else 0
            val2 = l2.val if l2 else 0
            
            # Calculate total sum for this position
            total = val1 + val2 + carry
            carry = total // 10
            new_digit = total % 10
            
            # Create a new node for the digit and move the pointer
            curr.next = ListNode(new_digit)
            curr = curr.next
            
            # Move to the next nodes in l1 and l2
            l1 = l1.next if l1 else None
            l2 = l2.next if l2 else None
            
        return dummy.next
